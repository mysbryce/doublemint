{
  "name": "doublemint",
  "version": "0.1.0",
  "description": "Production-grade .dlm to C++20 transpiler.",
  "type": "module",
  "bin": {
    "doublemint": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "runtime:embed": "node scripts/embed-runtime.mjs",
    "prebuild": "pnpm runtime:embed",
    "pretest": "pnpm runtime:embed",
    "build": "tsup",
    "check": "tsc --noEmit",
    "pack:vsix": "node scripts/pack-vsix.mjs",
    "build:examples": "node scripts/build-examples.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli.ts"
  },
  "engines": {
    "node": ">=20.11"
  },
  "packageManager": "pnpm@11.0.9",
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
