{
  "name": "doublemint",
  "version": "0.0.1-dev-36",
  "description": "Production-grade .dlm to C++20 transpiler.",
  "type": "module",
  "bin": {
    "doublemint": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "runtime:embed": "node scripts/embed-runtime.mjs",
    "manifest:refresh": "node scripts/refresh-manifest.mjs",
    "prebuild": "pnpm runtime:embed && pnpm manifest:refresh",
    "pretest": "pnpm runtime:embed && pnpm manifest:refresh",
    "build": "tsup",
    "check": "tsc --noEmit",
    "pack:vsix": "node scripts/pack-vsix.mjs",
    "build:examples": "node scripts/build-examples.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:check-style": "node scripts/check-docs-style.mjs"
  },
  "engines": {
    "node": ">=20.11"
  },
  "packageManager": "pnpm@11.0.9",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.15.29",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
