{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Doublemint",
  "scopeName": "source.doublemint",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#extern-header"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.doublemint",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.doublemint",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.doublemint",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.doublemint",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "extern-header": {
      "patterns": [
        {
          "name": "meta.extern.doublemint",
          "match": "\\b(extern)\\s+(\"[^\"]+\")",
          "captures": {
            "1": {
              "name": "keyword.control.import.doublemint"
            },
            "2": {
              "name": "string.quoted.double.include.doublemint"
            }
          }
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.doublemint",
          "match": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.function.doublemint"
            },
            "2": {
              "name": "entity.name.function.doublemint"
            }
          }
        },
        {
          "name": "meta.struct.doublemint",
          "match": "\\b(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.struct.doublemint"
            },
            "2": {
              "name": "entity.name.type.struct.doublemint"
            }
          }
        },
        {
          "name": "meta.typealias.doublemint",
          "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.type.doublemint"
            },
            "2": {
              "name": "entity.name.type.alias.doublemint"
            }
          }
        },
        {
          "name": "meta.import.doublemint",
          "match": "\\b(import)(?:\\s+(type))?\\b",
          "captures": {
            "1": {
              "name": "keyword.control.import.doublemint"
            },
            "2": {
              "name": "storage.type.type.doublemint"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.doublemint",
          "match": "\\b(?:if|else|while|for|switch|case|default|return|as)\\b"
        },
        {
          "name": "storage.modifier.doublemint",
          "match": "\\b(?:export|let|const|constexpr|copy)\\b"
        },
        {
          "name": "storage.type.function.arrow.doublemint",
          "match": "\\bfn\\b|=>"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.doublemint",
          "match": "\\bprint\\b"
        },
        {
          "name": "constant.language.boolean.doublemint",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.doublemint",
          "match": "\\b(?:void|int|float|double|string|bool)\\b"
        },
        {
          "name": "support.type.function.doublemint",
          "match": "\\bfunction\\b(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.doublemint",
          "match": "==|!=|<=|>=|=>|[-+*/=<>.]"
        },
        {
          "name": "punctuation.separator.doublemint",
          "match": "[,:;]"
        },
        {
          "name": "punctuation.bracket.doublemint",
          "match": "[(){}\\[\\]]"
        }
      ]
    }
  }
}

